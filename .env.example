# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Vercel KV (Redis) — used for settings storage and rate limiting
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin panel password
ADMIN_PASSWORD=

# Bypasses rate limiting for local dev / testing
DEV_TOKEN=

# Comma-separated list of allowed origins for /api/generate
# Set to your production domain in Vercel — e.g. https://tall-e.nl
# Leave unset (or *) during local development
ALLOWED_ORIGINS=https://tall-e.nl
